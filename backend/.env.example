# Backend Environment Template
# Duplicate this file to .env and fill in the values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chefsync

# Security
SECRET_KEY=generate_a_strong_random_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# NVIDIA NIM AI
NVIDIA_API_KEY=nvapi-xxxx-xxxx
VISION_MODEL=nvidia/llama-3.2-11b-vision-instruct
RECIPE_MODEL=meta/llama-3.1-405b-instruct

# Production
ALLOWED_ORIGINS=http://localhost:3000,https://chefsync.app
PORT=8000
